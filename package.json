{
  "name": "monitor-switcher-electron",
  "version": "2.2.0",
  "description": "Aplicativo de bandeja para alternar entre monitores usando MultiMonitorTool",
  "main": "main.js",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "start": "electron .",
    "test": "jest",
    "build": "electron-builder",
    "dist": "electron-builder --publish=never",
    "dist:publish": "electron-builder --publish always",
    "pack": "electron-builder --dir"
  },
  "keywords": [
    "electron",
    "monitor",
    "switcher",
    "tray",
    "multi-monitor"
  ],
  "author": "Alessandro Willian",
  "license": "MIT",
  "devDependencies": {
    "electron": "^43.2.0",
    "electron-builder": "^26.15.3",
    "jest": "^30.4.2"
  },
  "dependencies": {
    "csv-parse": "^6.2.1",
    "electron-updater": "^6.8.9"
  },
  "build": {
    "appId": "com.private.monitorswitcher",
    "productName": "Monitor Switcher",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "modules/**/*.js"
    ],
    "extraResources": [
      {
        "from": "MultiMonitorTool.exe",
        "to": "MultiMonitorTool.exe"
      },
      {
        "from": "display_config.txt",
        "to": "display_config.txt"
      },
      {
        "from": "monitorswitcher.ico",
        "to": "monitorswitcher.ico"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "monitorswitcher.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "awilliansd",
        "repo": "monitor-switcher",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "runAfterFinish": true
    }
  }
}
